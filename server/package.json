    "express": "^5.1.0",
    "express-rate-limit": "^8.0.0",
    "google-auth-library": "^10.1.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.16.0",
    "morgan": "^1.10.0",
    "nodemailer": "^9.0.3",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "eslint": "^9.30.0",
    "globals": "^16.3.0",
    "jest": "^30.0.4",
    "mongodb-memory-server": "^10.1.4",
    "nodemon": "^3.1.10",
